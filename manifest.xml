<?xml version="1.0" encoding="UTF-8"?>
<!--
 * File 3: The Routing Pointer (manifest.xml)
 * Purpose: Configuration file telling Outlook where to find the HTML/JS, permissions, and event hooks.
-->
<OfficeApp
          xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
          xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
          xsi:type="MailApp">
  
  <!-- Unique identifier for the add-in. Do not change once deployed -->
  <Id>b5a2794d-4aa5-4023-bf28-7136f564be10</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Toluna</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  
  <DisplayName DefaultValue="DLP: External Send Alert PoC" />
  <Description DefaultValue="Proof of Concept for blocking external emails with attachments." />
  
  <!-- Icons must be .png with valid dimensions (64x64 and 128x128) -->
  <IconUrl DefaultValue="https://abrar1108.github.io/ExternalSendAlert/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://abrar1108.github.io/ExternalSendAlert/icon-128.png" />
  <SupportUrl DefaultValue="https://abrar1108.github.io/ExternalSendAlert/" />
  
  <!-- GitHub Pages domain -->
  <AppDomains>
    <AppDomain>https://abrar1108.github.io</AppDomain>
  </AppDomains>
  
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>
  
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://abrar1108.github.io/ExternalSendAlert/commands.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>
  
  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  
  <!-- VersionOverrides V1_0 (outer wrapper for backwards compatibility) -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="WebViewRuntime.Url" />
          <!-- MessageComposeCommandSurface is required even if we only use LaunchEvent -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeCmdGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>checkExternalAttachments</FunctionName>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/icon-64.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/icon-64.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/icon-128.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="WebViewRuntime.Url" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/commands.html" />
        <bt:Url id="JSRuntime.Url" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/commands.js" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="External Send Alert" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Check External" />
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Checks for external recipients with attachments" />
      </bt:ShortStrings>
    </Resources>

    <!-- VersionOverrides V1_1 (inner, required for LaunchEvent / Smart Alerts) -->
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.12">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>
      <Hosts>
        <Host xsi:type="MailHost">
          <!-- Runtimes section required for event-based activation -->
          <Runtimes>
            <Runtime resid="WebViewRuntime.Url">
              <Override type="javascript" resid="JSRuntime.Url" />
            </Runtime>
          </Runtimes>
          <DesktopFormFactor>
            <FunctionFile resid="WebViewRuntime.Url" />
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeCmdGroup2">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="msgComposeOpenPaneButton2">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>checkExternalAttachments</FunctionName>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
            <!-- Smart Alerts LaunchEvent extension point -->
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnMessageSend" FunctionName="checkExternalAttachments" SendMode="PromptUser" />
              </LaunchEvents>
              <SourceLocation resid="WebViewRuntime.Url" />
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/icon-64.png" />
          <bt:Image id="Icon.32x32" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/icon-64.png" />
          <bt:Image id="Icon.80x80" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/icon-128.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="WebViewRuntime.Url" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/commands.html" />
          <bt:Url id="JSRuntime.Url" DefaultValue="https://abrar1108.github.io/ExternalSendAlert/commands.js" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="External Send Alert" />
          <bt:String id="TaskpaneButton.Label" DefaultValue="Check External" />
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Checks for external recipients with attachments" />
        </bt:ShortStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
